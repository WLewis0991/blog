# Backend .gitignore

# Environment variables
.env
.env.*
!.env.example

# Dependencies
node_modules/
vendor/
venv/
.venv/
env/
__pycache__/
*.pyc
*.pyo

# Build output
dist/
build/
out/
target/
*.egg-info/
*.egg

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Database
*.sqlite
*.sqlite3
*.db
*.sql

# Secrets & certs
*.pem
*.key
*.cert
*.p12
*.pfx

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Testing & coverage
coverage/
.coverage
.pytest_cache/
htmlcov/

# Docker
.dockerignore
docker-compose.override.yml

# Temp files
tmp/
temp/
*.tmp
*.bak 